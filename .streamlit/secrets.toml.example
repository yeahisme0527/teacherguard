# =============================================================
# 티쳐가드 — Supabase 키 설정 예시
# -------------------------------------------------------------
# 이 파일을 같은 폴더의 `secrets.toml` 로 복사한 뒤
# 본인 Supabase 프로젝트의 값으로 바꿔주세요.
#
# 키 찾는 곳:
#   Supabase 대시보드 → Project Settings → API
#     - Project URL          → url
#     - Project API keys → anon / public → anon_key
#
# `secrets.toml` 은 .gitignore 에 이미 포함되어 있어
# 깃에 올라가지 않습니다.
# =============================================================

[supabase]
url      = "YOUR_SUPABASE_URL"          # 예: https://xxxxx.supabase.co
anon_key = "YOUR_SUPABASE_ANON_KEY"     # 예: eyJhbGci...

# -------------------------------------------------------------
# (선택) HuggingFace 토큰 — kor_unsmile 혐오표현 탐지 모델용
#   없어도 앱은 동작하며, 이 경우 키워드 기반 탐지만 사용합니다.
#   토큰 발급: https://huggingface.co/settings/tokens (Read 권한)
# -------------------------------------------------------------
[huggingface]
token = "YOUR_HUGGINGFACE_TOKEN"        # 예: hf_xxxxxxxx
